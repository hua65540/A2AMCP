{
  "name": "a2a-chat-mcp",
  "version": "0.1.0",
  "description": "Local stdio MCP server for A2A AI business chat handoff workflows.",
  "author": "hua65540",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/hua65540/A2AMCP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hua65540/A2AMCP.git"
  },
  "bugs": {
    "url": "https://github.com/hua65540/A2AMCP/issues"
  },
  "bin": {
    "a2a-chat-mcp": "./dist/index.js"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "dist",
    "docs",
    "README.md",
    "skills",
    "scripts/validate-skills.mjs"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/index.js",
    "test": "vitest run",
    "validate:skills": "node scripts/validate-skills.mjs",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "codex",
    "a2a",
    "handoff",
    "chat"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
